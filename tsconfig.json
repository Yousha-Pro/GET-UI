{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "dom", "webworker"],
    "types": ["chrome"]
  },
  "include": ["**/*.js", "**/*.mjs"],
  "exclude": ["node_modules"]
}
